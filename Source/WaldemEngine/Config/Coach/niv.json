{
  "loss": {
    "otype": "RelativeL2"
  },
  "optimizer": {
    "otype": "ExponentialDecay",
    "decay_base": 0.33,
    "decay_interval": 10000,
    "decay_start": 10000,
    "decay_end": 50000,
    "nested": {
      "otype": "Adam",
      "learning_rate": 0.001
    }
  },
  "encoding": {
    "otype": "Composite",
    "nested": [
      {
        "n_dims_to_encode": 3,
        "otype": "HashGrid",
        "n_levels": 8,
        "n_features_per_level": 4,
        "log2_hashmap_size": 19,
        "base_resolution": 16,
        "per_level_scale": 2.0
      },
      {
        "n_dims_to_encode": 2,
        "otype": "Identity"
      }
    ]
  },
  "network": {
    "otype": "FullyFusedMLP",
    "activation": "ReLU",
    "output_activation": "None",
    "n_neurons": 64,
    "n_hidden_layers": 3
  }
}
